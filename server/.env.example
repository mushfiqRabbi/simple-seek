# SimpleSeek Server Configuration

PORT=3001

# Turso (Hosted SQLite) — get these from: https://turso.tech
# 1. Install CLI:   curl -sSfL https://get.turso.tech | bash
# 2. Sign in:       turso auth login
# 3. Create DB:     turso db create simpleseek
# 4. Get URL:       turso db show simpleseek --url
# 5. Get token:     turso db tokens create simpleseek
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# Pi coding agent uses its own provider configuration (set via `pi` CLI/TUI).
# No API keys needed here.
